# Environment variables — [PROJECT NAME]
# Copy this file to .env.local and fill in the values
# Never commit .env.local

# ─── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=               # Project URL (https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Anon key — public, safe for client-side use
SUPABASE_SERVICE_ROLE_KEY=              # Service key — NEVER prefix with NEXT_PUBLIC_

# ─── Auth (if applicable) ──────────────────────────────────
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=                      # openssl rand -base64 32

# ─── Email (Resend) ────────────────────────────────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=studio@sqwr.be

# ─── Analytics ─────────────────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=         # Plausible domain (without https://)

# ─── AI / OpenRouter (if applicable) ──────────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-3-5-sonnet

# ─── Vercel KV (if applicable) ─────────────────────────────
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ─── Miscellaneous ─────────────────────────────────────────
# NODE_ENV=development                  # development | production | test
