# Variables d'environnement — [NOM DU PROJET]
# Copier ce fichier en .env.local et remplir les valeurs
# Ne jamais committer .env.local

# ─── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=               # URL du projet (https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Clé anon — publique, ok côté client
SUPABASE_SERVICE_ROLE_KEY=              # Clé service — JAMAIS préfixée NEXT_PUBLIC_

# ─── Auth (si applicable) ──────────────────────────────────
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=                      # openssl rand -base64 32

# ─── Email (Resend) ────────────────────────────────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=studio@sqwr.be

# ─── Analytics ─────────────────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=         # domaine Plausible (sans https://)

# ─── IA / OpenRouter (si applicable) ──────────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-3-5-sonnet

# ─── Vercel KV (si applicable) ─────────────────────────────
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ─── Divers ────────────────────────────────────────────────
# NODE_ENV=development                  # development | production | test
