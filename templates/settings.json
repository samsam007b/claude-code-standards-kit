{
  "_comment": "Claude Code settings template — Claude Code Standards Kit by SQWR Studio",
  "_instructions": "Copy to .claude/settings.json (project-level) or ~/.claude/settings.json (global). Replace KIT_PATH with your kit path. See CONTRACT-TOKEN-ECONOMY for rationale.",

  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "medium",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "16384",
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  },

  "effortLevel": "medium",
  "autoCompactWindow": 60000,
  "skipDangerousModePermissionPrompt": true,

  "permissions": {
    "defaultMode": "bypassPermissions"
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash KIT_PATH/hooks/scripts/hook-no-secrets.sh",
            "_comment": "CONTRACT-SECURITY §2 — blocks committing secrets (OWASP A02)"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash KIT_PATH/hooks/scripts/hook-no-dangerous-html.sh",
            "_comment": "CONTRACT-SECURITY §2 — warns on unsafe HTML injection (OWASP A03: XSS)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash KIT_PATH/hooks/scripts/hook-contract-compliance.sh",
            "_comment": "All active contracts — warns on: excessive any types, @ts-ignore, console.log, missing img alt"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash KIT_PATH/hooks/scripts/hook-subagent-output.sh",
            "_comment": "CONTRACT-TOKEN-ECONOMY TE-5.1 — alerts if subagent output exceeds 800 words"
          }
        ]
      }
    ]
  }
}
